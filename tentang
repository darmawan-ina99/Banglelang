        .btn:hover { transform: translateY(-2px); box-shadow: 0 10px 25px rgba(0,0,0,0.3); }
        footer { background: var(--navy); text-align: center; padding: 30px 20px; margin-top: 50px; color: #8892b0; font-size: 0.9em; }
